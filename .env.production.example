# Copy this to .env.production on the VM and fill in real values.
# NEVER commit the real .env.production file to git.

POSTGRES_USER=relay
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=relay
DATABASE_URL=postgres://relay:CHANGE_ME_strong_random_password@db:5432/relay

PORT=4000
NODE_ENV=production
DEV_AUTH=false
SESSION_SECRET=CHANGE_ME_random_string

WEB_ORIGIN=https://relay.alphasights.ae
VITE_API_URL=https://relay.alphasights.ae/api

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://relay.alphasights.ae/api/auth/callback

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
