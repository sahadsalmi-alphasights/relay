    "dotenv": "^16.4.7",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "node-pg-migrate": "^9.0.0",
    "openid-client": "^5.7.1",
    "pg": "^8.13.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
