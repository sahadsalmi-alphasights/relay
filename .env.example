# Copy this to .env before running `docker compose up`.
# DUMMY DEV VALUES ONLY — never put real credentials in this repo (see spec §1.6).

POSTGRES_USER=relay
POSTGRES_PASSWORD=relay_dev_password
POSTGRES_DB=relay

# Inside the compose network the DB is reachable at host "db".
DATABASE_URL=postgres://relay:relay_dev_password@db:5432/relay

PORT=4000
NODE_ENV=development

# DEV_AUTH bypasses OIDC and lets you pick a seeded dummy user (spec §7).
# The server refuses to boot with DEV_AUTH=true when NODE_ENV=production.
DEV_AUTH=true

SESSION_SECRET=dev_only_change_me

# Origin the web app is served from — used for CORS (cookies need an exact
# origin, not a wildcard) and by the web app itself to reach the API.
WEB_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4000

# Real OIDC provider is TBC (Okta / Azure AD / Google Workspace / ...) — leave
# blank locally while DEV_AUTH=true. The server refuses to boot with
# DEV_AUTH=false unless ALL FOUR of these are set (see README "Environment
# variables" for what to send back once IT has registered the app with SSO).
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# Web push (spec §9->built) — generate your own pair, these are not real keys:
# node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@example.test
